# CREON Relay — environment config
# Copy to .env and fill in your values

# Port for relay server (default 18900)
PORT=18900

# OpenClaw gateway URL (your cloudflared tunnel)
OPENCLAW_GATEWAY_URL=https://your-tunnel.trycloudflare.com

# OpenClaw gateway token (from openclaw.json)
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# OpenClaw agent ID (default: main)
OPENCLAW_AGENT_ID=main

# Newsdata.io API key for research signals feed
NEWSDATA_API_KEY=your_newsdata_key_here

# Dashboard URL for CORS (default: all origins)
DASHBOARD_ORIGIN=https://creon.live
